<!DOCTYPE RCC>
<RCC version="1.0">
  <qresource prefix="/icons">
    <file alias="carla-studio-16.png">linux/icons/hicolor/16x16/apps/carla-studio.png</file>
    <file alias="carla-studio-32.png">linux/icons/hicolor/32x32/apps/carla-studio.png</file>
    <file alias="carla-studio-48.png">linux/icons/hicolor/48x48/apps/carla-studio.png</file>
    <file alias="carla-studio-64.png">linux/icons/hicolor/64x64/apps/carla-studio.png</file>
    <file alias="carla-studio-128.png">linux/icons/hicolor/128x128/apps/carla-studio.png</file>
    <file alias="carla-studio-256.png">linux/icons/hicolor/256x256/apps/carla-studio.png</file>
    <file alias="carla-studio-512.png">linux/icons/hicolor/512x512/apps/carla-studio.png</file>
  </qresource>
  <qresource prefix="/examples">
    <file alias="empty_flat.xodr">examples/empty_flat.xodr</file>
    <file alias="two_lane_10mi.xodr">examples/two_lane_10mi.xodr</file>
    <file alias="sample_osm_rural.xodr">examples/sample_osm_rural.xodr</file>
    <file alias="scenario_town01_demo.json">examples/scenario_town01_demo.json</file>
  </qresource>
  <qresource prefix="/meta">
    <file alias="CHANGELOG.md">../CHANGELOG.md</file>
    <file alias="LICENSE">../LICENSE</file>
    <file alias="THIRD_PARTY.md">../LICENSES/THIRD_PARTY.md</file>
    <file alias="CITATION.cff">../CITATION.cff</file>
    <file alias="CONTRIBUTING.md">../CONTRIBUTING.md</file>
  </qresource>
  <qresource prefix="/plugin_patches">
    <file alias="CarlaTools/VehicleImporter.h">plugin_patches/CarlaTools/VehicleImporter.h</file>
    <file alias="CarlaTools/VehicleImporter.cpp">plugin_patches/CarlaTools/VehicleImporter.cpp</file>
    <file alias="CarlaTools/CarlaTools.cpp">plugin_patches/CarlaTools/CarlaTools.cpp</file>
  </qresource>
  <qresource prefix="/integrations">
    <file alias="scripts/start.sh">integrations/scripts/start.sh</file>
    <file alias="scripts/stop.sh">integrations/scripts/stop.sh</file>
    <file alias="scripts/wait_functions.sh">integrations/scripts/wait_functions.sh</file>
    <file alias="scripts/setup/advanced_build_autoware.sh">integrations/scripts/setup/advanced_build_autoware.sh</file>
    <file alias="scripts/setup/build_autoware.sh">integrations/scripts/setup/build_autoware.sh</file>
    <file alias="scripts/setup/carla_launcher.sh">integrations/scripts/setup/carla_launcher.sh</file>
    <file alias="scripts/setup/check_dependency_status.sh">integrations/scripts/setup/check_dependency_status.sh</file>
    <file alias="scripts/setup/keep_alive.sh">integrations/scripts/setup/keep_alive.sh</file>
    <file alias="scripts/setup/manage_sleep.sh">integrations/scripts/setup/manage_sleep.sh</file>
    <file alias="scripts/setup/quick_autoware_setup.sh">integrations/scripts/setup/quick_autoware_setup.sh</file>
    <file alias="scripts/setup/setup_autoware.sh">integrations/scripts/setup/setup_autoware.sh</file>
    <file alias="scripts/setup/test_terminal5_fix.sh">integrations/scripts/setup/test_terminal5_fix.sh</file>
    <file alias="scripts/setup/validate_10_terminals.sh">integrations/scripts/setup/validate_10_terminals.sh</file>
    <file alias="scripts/setup/validate_implementations.sh">integrations/scripts/setup/validate_implementations.sh</file>
    <file alias="run/terminal5_cosim_runner.sh">integrations/run/terminal5_cosim_runner.sh</file>
    <file alias="run/terminal8_preview_runner.sh">integrations/run/terminal8_preview_runner.sh</file>
    <file alias="run/terminal9_scenario_runner.sh">integrations/run/terminal9_scenario_runner.sh</file>
    <file alias="launch/terminal_launch_map.json">integrations/launch/terminal_launch_map.json</file>
    <file alias="rviz/carla_mcity_ros2.rviz">integrations/rviz/carla_mcity_ros2.rviz</file>
  </qresource>
</RCC>
